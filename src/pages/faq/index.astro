---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../site.config';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const budgetFaq = [
  {
    id: "b1",
    cat: "budget",
    q: "Quel est le prix moyen d'une chaudière à granulés en 2026, pose comprise ?",
    a: "Le tarif complet varie généralement entre <strong>8 000 € et 22 000 € TTC pose comprise</strong> en 2026. Cette large fourchette s'explique par plusieurs facteurs techniques : la puissance requise pour chauffer le logement (ex. de 12 à 25 kW), le type d'alimentation (alimentation manuelle par trémie plus abordable vs chargement 100 % automatique par vis sans fin ou aspiration pneumatique), et la capacité du silo de stockage. Pour un modèle standard automatique avec silo textile de taille moyenne (convenant à une maison de 120 m²), le budget se situe généralement entre <strong>11 000 € et 14 000 € TTC installé</strong> avant déduction des aides financières publiques."
  },
  {
    id: "b2",
    cat: "budget",
    q: "Quelle est la durée d'amortissement réelle de ce type de chauffage ?",
    a: "Le temps de retour sur investissement moyen est estimé entre <strong>4 et 7 ans</strong>. Il s'avère particulièrement court (souvent moins de 5 ans) si vous remplacez un chauffage au fioul domestique ou de vieux convecteurs électriques énergivores. Les économies annuelles substantielles sur la facture de combustible (de l'ordre de 50 % à 70 % selon l'énergie précédente) alliées aux aides à l'installation massives (MaPrimeRénov' de l'Anah et primes CEE) permettent de réduire drastiquement le reste à charge et d'amortir l'investissement de départ à vitesse grand V."
  },
  {
    id: "b3",
    cat: "budget",
    q: "Le prix des granulés de bois (pellets) est-il stable face à l'électricité ou au gaz ?",
    a: "Oui, la stabilité est l'un des plus grands atouts du granulé de bois. Après les perturbations temporaires dues à la crise énergétique mondiale de 2022-2023, le marché français s'est solidement restructuré. Grâce à la création de multiples usines de granulation sur le territoire national, la filière française produit désormais plus de 95 % des pellets consommés localement. En 2026, le prix se stabilise durablement entre <strong>300 € et 420 € la tonne en vrac</strong> (livrée par camion). À pouvoir calorifique équivalent, le pellet s'impose comme l'énergie de chauffage central la moins chère et la plus décorrélée des tensions géopolitiques."
  },
  {
    id: "b4",
    cat: "budget",
    q: "Combien coûte l'entretien annuel obligatoire et le ramonage ?",
    a: "Le coût annuel moyen oscille entre <strong>150 € et 350 € TTC</strong>. Ce budget englobe la visite technique obligatoire d'entretien de la chaudière (nettoyage complet du corps de chauffe, vérification des systèmes de sécurité et contrôle de la combustion) ainsi que les <strong>deux ramonages mécaniques du conduit de fumée imposés par la loi</strong> (dont l'un doit impérativement être effectué pendant la période de chauffe active). Opter pour un contrat d'entretien annuel chez un installateur RGE Qualibois agréé permet souvent d'obtenir des dépannages rapides inclus à tarif préférentiel."
  },
  {
    id: "b5",
    cat: "budget",
    q: "Quel est le prix à la tonne des pellets en sac vs en vrac ?",
    a: "Le tarif à la tonne dépend du conditionnement et de la logistique : <ul><li><strong>En vrac (livraison par camion souffleur)</strong> : le prix oscille entre <strong>300 € et 420 € la tonne</strong> pour une livraison minimale de 2 à 3 tonnes. C'est l'option la plus économique et confortable si vous avez un silo de stockage automatique.</li><li><strong>En sacs (sur palette)</strong> : le prix moyen d'une palette de 66 ou 72 sacs de 15 kg (environ 1 tonne) se situe entre <strong>380 € et 490 €</strong> selon la marque et le distributeur. C'est la solution adaptée aux chaudières à trémie manuelle ou si vous manquez d'espace de stockage en vrac.</li></ul>"
  },
  {
    id: "b6",
    cat: "budget",
    q: "Combien économise-t-on réellement par an par rapport au fioul ou au gaz ?",
    a: "Pour une maison individuelle de 120 m² moyennement isolée (consommation annuelle estimée à ~18 000 kWh thermiques), les économies de combustible annuelles sont considérables : <ul><li><strong>Par rapport au fioul domestique</strong> : vous économisez entre <strong>1 200 € et 2 200 € par an</strong>, le fioul étant un dérivé du pétrole soumis à de lourdes taxes carbone.</li><li><strong>Par rapport au gaz propane (en citerne)</strong> : les économies s'élèvent à près de <strong>1 500 € à 2 500 € par an</strong>.</li><li><strong>Par rapport au gaz naturel (de ville)</strong> : vous réalisez de <strong>600 € à 1 200 € d'économies annuelles</strong> selon l'évolution des tarifs réglementés.</li></ul>"
  }
];

const aidsFaq = [
  {
    id: "a1",
    cat: "aids",
    q: "Quelles sont les aides cumulables en 2026 pour l'achat d'une chaudière biomasse ?",
    a: "Pour encourager la transition écologique, vous pouvez cumuler jusqu'à 5 dispositifs majeurs en 2026 : <ol><li><strong>MaPrimeRénov' de l'Anah</strong> : jusqu'à 10 000 € pour les ménages aux revenus très modestes.</li><li><strong>La Prime Énergie CEE (Certificats d'Économie d'Énergie)</strong> : d'une valeur de 2 500 € à 4 500 € selon votre niveau de ressources.</li><li><strong>Le Bonus Sortie de Fioul</strong> : une aide forfaitaire supplémentaire de 1 000 € si vous procédez au démontage et à la neutralisation de votre ancienne cuve à fioul.</li><li><strong>La TVA à taux super-réduit de 5,5 %</strong> : appliquée directement par votre installateur sur le matériel et la main d'œuvre.</li><li><strong>L'Éco-Prêt à Taux Zéro (Éco-PTZ)</strong> : un financement sans intérêts jusqu'à 30 000 € remboursable sur 15 ans pour couvrir votre reste à charge.</li></ol>"
  },
  {
    id: "a2",
    cat: "aids",
    q: "La certification RGE Qualibois de l'installateur est-elle obligatoire ?",
    a: "Oui, elle est **strictement obligatoire et non négociable**. Pour prétendre à la moindre aide d'État (MaPrimeRénov'), aux primes CEE ou à l'Éco-PTZ, votre projet doit être intégralement réalisé par un professionnel certifié **RGE (Reconnu Garant de l'Environnement) Qualibois module Eau** (chauffage central biomasse). Assurez-vous d'exiger une copie du certificat RGE à jour lors de la signature du devis et vérifiez que sa période de validité couvre bien le moment des travaux."
  },
  {
    id: "a3",
    cat: "aids",
    q: "Les propriétaires bailleurs et résidences secondaires sont-ils éligibles aux aides ?",
    a: "Les **propriétaires bailleurs sont pleinement éligibles** à MaPrimeRénov' en 2026 (dans la limite de 3 logements mis en location comme résidence principale sur une période de 5 ans) afin d'éradiquer les passoires thermiques locatives. En revanche, les **résidences secondaires ne sont pas éligibles** aux subventions de l'Anah (MaPrimeRénov'), mais elles restent pleinement éligibles aux primes CEE (primes énergie du privé) et à la TVA réduite à 5,5 %."
  },
  {
    id: "a4",
    cat: "aids",
    q: "Comment monter son dossier d'aides sans risquer un rejet administratif ?",
    a: "La règle d'or absolue pour éviter tout rejet est la suivante : **vous devez impérativement créer vos comptes en ligne et déposer vos demandes d'aides (portail MaPrimeRénov' et CEE) AVANT de signer le moindre devis** ou de verser le moindre acompte financier à votre artisan. Tout devis signé ou daté (même d'un seul jour) avant le dépôt officiel de votre demande d'aide entraînera le rejet irréversible de votre dossier par l'administration."
  },
  {
    id: "a5",
    cat: "aids",
    q: "Quelle est la TVA applicable pour l'installation d'une chaudière à granulés ?",
    a: "Les travaux de rénovation énergétique axés sur les énergies renouvelables bénéficient d'un taux de **TVA très avantageux à 5,5 %** (au lieu du taux standard de 20 %). Ce taux réduit s'applique automatiquement sur la facture émise par l'entreprise RGE, et couvre à la fois l'achat de la chaudière biomasse, le silo, le raccordement hydraulique, le ballon tampon, le tubage de cheminée et la main-d'œuvre associée."
  },
  {
    id: "a6",
    cat: "aids",
    q: "Existe-t-il des aides locales régionales ou départementales supplémentaires ?",
    a: "Oui, de nombreuses collectivités locales (Régions, Départements, Métropoles ou Communes) proposent des aides financières spécifiques pour inciter les foyers à abandonner les énergies fossiles. Par exemple, la région Auvergne-Rhône-Alpes, le Grand Est ou l'Occitanie disposent de dispositifs d'accompagnement cumulables avec MaPrimeRénov'. Rapprochez-vous d'un conseiller France Rénov' de votre secteur pour réaliser un plan de financement exhaustif."
  }
];

const techFaq = [
  {
    id: "t1",
    cat: "tech",
    q: "Comment fonctionne exactement le système d'alimentation automatique ?",
    a: "Les chaudières automatiques transportent le granulé du silo vers le brûleur de manière autonome via deux grands procédés : <ul><li><strong>La vis sans fin physique (vis d'Archimède)</strong> : un moteur fait tourner une spirale en acier dans un tube rigide, déplaçant mécaniquement les pellets. C'est simple, très fiable et peu coûteux, mais cela impose que le silo soit collé à la chaudière (distance max < 6 mètres, en ligne droite).</li><li><strong>L'aspiration pneumatique</strong> : une turbine d'aspiration crée une dépression et aspire les granulés via deux tuyaux flexibles souples. Ce système permet d'éloigner le silo jusqu'à 20 mètres de la chaudière, de franchir des angles à 90° ou de passer à travers des cloisons et des étages.</li></ul>"
  },
  {
    id: "t2",
    cat: "tech",
    q: "Quelle puissance de chaudière (en kW) choisir pour une maison de 100 à 150 m² ?",
    a: "Pour une maison individuelle de 100 à 150 m² moyennement isolée en France métropolitaine, la puissance thermique requise se situe en général entre **12 kW et 20 kW**. Il est extrêmement important de faire réaliser un bilan thermique (ou dimensionnement précis) par un professionnel certifié RGE Qualibois. **Évitez à tout prix le surdimensionnement** : une chaudière trop puissante par rapport aux besoins réels fonctionnera par à-coups (cycles courts d'allumage), ce qui augmente la consommation de pellets, sollicite excessivement la bougie d'allumage et écourte la durée de vie du matériel."
  },
  {
    id: "t3",
    cat: "tech",
    q: "Pourquoi l'installation d'un ballon tampon est-elle indispensable ?",
    a: "Le ballon tampon agit comme une réserve d'eau chaude technique intermédiaire. Il stocke l'énergie thermique produite en excès par la chaudière et la redistribue progressivement dans vos radiateurs ou votre plancher chauffant. Son rôle est capital car il évite à la chaudière de s'allumer et de s'éteindre de manière répétée (phénomène destructeur de cycles courts). Grâce au ballon tampon, la chaudière tourne à son régime optimal à plein rendement, ce qui permet d'économiser jusqu'à 15 % de pellets et de préserver les composants électriques (bougie d'allumage)."
  },
  {
    id: "t4",
    cat: "tech",
    q: "La chaudière à granulés à condensation est-elle rentable pour tous les logements ?",
    a: "Non. Une chaudière à condensation récupère l'énergie thermique latente contenue dans les vapeurs d'eau des fumées de combustion. Pour que ce phénomène physique fonctionne (point de rosée), l'eau de retour du circuit de chauffage doit être froide (inférieure à 45°C). Elle est donc **hautement recommandée et rentable si votre logement est équipé d'émetteurs basse température** (plancher chauffant hydraulique ou radiateurs à eau basse température). Si vous disposez de vieux radiateurs en fonte haute température, la condensation ne se fera jamais : une chaudière modulante classique sera alors bien plus adaptée et économique à l'achat."
  },
  {
    id: "t5",
    cat: "tech",
    q: "Une chaudière à granulés peut-elle aussi produire l'eau chaude sanitaire (ECS) ?",
    a: "Oui, tout à fait. Les chaudières à pellets modernes gèrent parfaitement la production d'eau chaude sanitaire pour toute la famille. Elles peuvent être connectées à un ballon d'eau chaude intégré ou déporté (ballon bi-énergie, préparateur ECS ou ballon thermodynamique). La régulation intelligente de la chaudière donne systématiquement la priorité à la production d'eau chaude sanitaire pour vous garantir un confort thermique ininterrompu toute l'année, même en été (où la chaudière ne s'allume que brièvement pour chauffer l'eau du ballon)."
  },
  {
    id: "t6",
    cat: "tech",
    q: "Que se passe-t-il en cas de coupure d'électricité ?",
    a: "Comme n'importe quelle chaudière moderne à combustion régulée (au gaz ou au fioul) ou comme une pompe à chaleur, la chaudière à granulés **a besoin d'alimentation électrique pour fonctionner**. L'électricité alimente la régulation électronique de bord, le moteur d'amenée des granulés (vis sans fin), la turbine d'extraction des fumées, la bougie d'allumage et les circulateurs d'eau du réseau de chauffage. En cas de panne de courant, la chaudière s'éteint immédiatement en toute sécurité par étouffement progressif du foyer de combustion. Il est possible d'installer un petit onduleur de sauvegarde si votre zone géographique subit régulièrement des coupures de courant."
  }
];

const storageFaq = [
  {
    id: "s1",
    cat: "storage",
    q: "Quel type de silo choisir : textile, maçonné ou enterré ?",
    a: "Le choix du silo dépend de votre budget et de la configuration de votre habitation : <ul><li><strong>Silo textile en kit (recommandé)</strong> : suspendu sur une structure métallique ou en bois, il est étanche à la poussière, protège parfaitement de l'humidité ambiante et s'installe très rapidement dans un garage ou une cave. C'est le meilleur rapport qualité/prix.</li><li><strong>Silo maçonné ou autoconstruit (sur mesure)</strong> : il s'agit d'aménager une pièce étanche existante en créant des pentes à 35°-40° en bois (panneaux OSB) pour guider les granulés vers la vis d'extraction. Cela permet d'optimiser chaque centimètre cube disponible.</li><li><strong>Cuve enterrée (extérieur)</strong> : en plastique ou en béton, elle libère totalement l'espace intérieur de la maison, mais requiert des travaux de terrassement importants et un surcoût conséquent.</li></ul>"
  },
  {
    id: "s2",
    cat: "storage",
    q: "Combien d'espace physique faut-il prévoir pour stocker ses pellets ?",
    a: "Pour stocker la consommation annuelle moyenne d'une maison standard (environ 3 à 5 tonnes de granulés en vrac), vous devez allouer un espace au sol de **2 à 4 m²**, avec une hauteur sous plafond minimale de **2 mètres** pour loger un silo textile de taille adéquate ou créer un espace maçonné fonctionnel. Il est impératif que ce local technique soit situé à portée du tuyau de livraison du camion souffleur (généralement moins de 20 mètres)."
  },
  {
    id: "s3",
    cat: "storage",
    q: "Comment se déroule la livraison de granulés en vrac par camion souffleur ?",
    a: "Un camion citerne se déplace chez vous. Le livreur raccorde deux tuyaux flexibles à vos bouches d'alimentation extérieures (raccords pompiers Guillemin de diamètre 100). Le premier tuyau souffle les granulés de bois sous faible pression dans le silo, tandis que le second tuyau aspire les poussières fines générées lors du soufflage pour maintenir un espace propre. La livraison complète dure environ 30 à 45 minutes et s'effectue sans aucune manutention physique pour le propriétaire."
  },
  {
    id: "s4",
    cat: "storage",
    q: "Les pellets craignent-ils l'humidité ? Comment bien les stocker ?",
    a: "Oui, **l'humidité est l'ennemi juré absolue du pellet**. Fabriqué par forte compression de sciure sèche sans aucun liant chimique, le granulé de bois absorbe instantanément l'eau. Au contact de l'humidité, il gonfle, se désagrège sous forme de sciure compacte et perd tout son pouvoir calorifique. Surtout, la sciure humide risque de bloquer définitivement la vis sans fin de transfert ou d'obstruer le système d'aspiration de votre chaudière. Votre silo doit donc être installé dans un local technique parfaitement ventilé, hors d'eau et exempt de toute humidité résiduelle."
  },
  {
    id: "s5",
    cat: "storage",
    q: "Quelle quantité de granulés de bois consomme-t-on en moyenne par an ?",
    a: "Pour une maison individuelle classique de 120 m² habitée par 4 personnes et dotée d'une isolation moyenne (RT 2012 ou rénovée énergétiquement), la consommation annuelle moyenne de pellets oscille entre **2 et 4 tonnes** (pour le chauffage seul ou combiné avec la production d'eau chaude sanitaire). Cette consommation varie évidemment en fonction de la rigueur du climat de votre région, de la température de consigne intérieure (ex. 19°C vs 21°C) et de la qualité d'isolation globale du bâti."
  }
];

const brandFaq = [
  {
    id: "m1",
    cat: "brand",
    q: "Quelle est la durée de vie réelle d'une chaudière biomasse premium ?",
    a: "Une chaudière à granulés de qualité industrielle, bien installée et régulièrement entretenue (visite annuelle + ramonage), possède une durée de vie moyenne comprise entre **20 et 25 ans**. C'est une longévité équivalente voire supérieure à celle d'une chaudière fioul traditionnelle de l'ancienne génération, et nettement supérieure à celle d'une pompe à chaleur air-eau dont la durée de vie moyenne dépasse rarement 12 à 15 ans en raison de la fatigue rapide du compresseur thermodynamique."
  },
  {
    id: "m2",
    cat: "brand",
    q: "Quelles sont les meilleures marques de chaudières à granulés en 2026 ?",
    a: "Le marché haut de gamme est historiquement dominé par le savoir-faire autrichien et allemand. Les marques de référence incontournables incluent : <ul><li><strong>Ökofen</strong> : pionnier mondial de la chaudière biomasse, réputé pour sa technologie de pointe à condensation Pellematic.</li><li><strong>Hargassner</strong> : le summum de la robustesse mécanique et de la fiabilité électronique avec ses gammes Nano.</li><li><strong>Fröling</strong> : expert industriel allemand proposant d'excellents modèles à haut rendement (PE1, PE1 Condens).</li><li><strong>Viessmann & Windhager</strong> : constructeurs allemands haut de gamme réputés pour la compacité et la finition irréprochable de leurs appareils.</li><li><strong>Easypell</strong> : la marque alternative d'entrée/milieu de gamme sous licence technologique Ökofen, idéale pour un budget maîtrisé sans compromis sur la robustesse.</li></ul>"
  },
  {
    id: "m3",
    cat: "brand",
    q: "Comment choisir la certification des granulés (DINplus, ENplus A1, NF) ?",
    a: "Pour préserver le corps de chauffe de votre chaudière et optimiser son rendement, vous devez **impérativement acheter des granulés certifiés de qualité premium**. Privilégiez les trois certifications officielles suivantes qui garantissent un cahier des charges strict (taux d'humidité inférieur à 10 %, taux de cendres inférieur à 0,7 %, absence totale d'additifs chimiques, et longueur calibrée) : <ul><li><strong>DINplus</strong> (norme allemande d'origine, référence historique du marché).</li><li><strong>ENplus A1</strong> (norme européenne harmonisée, garantissant également le respect de la qualité lors du transport).</li><li><strong>NF Biomasse - Granulés biocombustibles</strong> (la certification officielle française).</li></ul>"
  },
  {
    id: "m4",
    cat: "brand",
    q: "À quelle fréquence faut-il vider le bac à cendres de la chaudière ?",
    a: "Grâce à des taux de combustion extrêmement performants (rendements supérieurs à 90-95 %), la quantité de cendres produite par le bois comprimé est minime. Sur les chaudières modernes équipées d'un système de compactage des cendres automatique vers un bac externe, vous n'aurez à vider le tiroir à cendres que **1 à 3 fois par saison de chauffe** seulement. Cette opération est très propre, prend moins de deux minutes et s'effectue facilement. De plus, les cendres de bois naturelles froides constituent un excellent engrais riche en potasse pour votre jardin ou potager !"
  },
  {
    id: "m5",
    cat: "brand",
    q: "Quelles sont les pannes les plus fréquentes et comment les éviter ?",
    a: "La très grande majorité des pannes sur une chaudière à granulés est liée à la qualité du combustible ou à un manque d'entretien basique : <ul><li><strong>Le blocage de la vis sans fin</strong> : provoqué par une accumulation excessive de poussière de bois (la \"fine\") au fond du silo. *Solution* : Vider et aspirer totalement le fond de votre silo de stockage tous les 2 ans avant la livraison.</li><li><strong>La formation de mâchefer sur le brûleur</strong> : dû à des pellets humides ou de piètre qualité qui fondent et bloquent l'arrivée d'air comburant. *Solution* : Utiliser exclusivement des pellets certifiés ENplus A1 ou DINplus.</li><li><strong>L'usure de la bougie ou résistance d'allumage</strong> : pièce d'usure standard soumise à de fortes contraintes thermiques lors des démarrages de combustion. *Solution* : Installer un ballon tampon pour réduire de 300 % le nombre d'allumages quotidiens requis.</li></ul>"
  }
];

const faqCategories = [
  { id: "all", name: "Toutes", icon: "📋" },
  { id: "budget", name: "Prix & Rentabilité", icon: "💰" },
  { id: "aids", name: "Aides & Finance", icon: "🏛️" },
  { id: "tech", name: "Technique & Pose", icon: "⚙️" },
  { id: "storage", name: "Stockage & Silos", icon: "📦" },
  { id: "brand", name: "Entretien & Marques", icon: "🔧" }
];

const allFaq = [...budgetFaq, ...aidsFaq, ...techFaq, ...storageFaq, ...brandFaq];

// FAQ JSON-LD formatting
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": allFaq.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a.replace(/<\/?[^>]+(>|$)/g, "") // Clean HTML tags for JSON schema compliance
      }
    }))
  }
];
---

<BaseLayout
  title={`FAQ Chaudière Granulés 2026 : Prix, Fonctionnement & Aides | ${siteConfig.name}`}
  description={`Toutes les réponses d'experts à vos questions sur le prix d'achat, l'installation, les aides de l'Anah et le stockage de la chaudière à granulés de bois.`}
  canonical="/faq"
  jsonLd={jsonLd}
>
  <!-- Hero Section -->
  <section class="gradient-hero text-white py-12 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(251,191,36,0.1),transparent)] pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <Breadcrumbs items={[
        { label: "FAQ", href: "/faq" },
      ]} />
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4 font-heading mt-6 tracking-tight">
        ❓ Foire Aux Questions (FAQ)
      </h1>
      <p class="text-amber-200 text-lg max-w-3xl font-medium leading-relaxed">
        Une question technique, administrative ou sur le budget ? Retrouvez les réponses exhaustives et certifiées de nos chauffagistes experts.
      </p>
    </div>
  </section>

  <!-- Interactive Controls Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 relative z-20">
    <div class="bg-white/90 backdrop-blur-md rounded-2xl border border-amber-200/60 p-6 shadow-xl space-y-6">
      
      <!-- Live Search Box -->
      <div class="relative max-w-2xl mx-auto">
        <label for="faq-search" class="sr-only">Rechercher une question</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-amber-600">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
