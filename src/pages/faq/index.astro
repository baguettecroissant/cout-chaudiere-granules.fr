---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../site.config';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": siteConfig.faq.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];
---

<BaseLayout
  title={`FAQ Chaudière Granulés : Prix, Fonctionnement & Aides 2026 | ${siteConfig.name}`}
  description={`Toutes les réponses à vos questions sur le prix, l'installation, les aides de l'État et l'entretien annuel d'une chaudière à granulés de bois.`}
  canonical="/faq"
  jsonLd={jsonLd}
>
  <section class="gradient-hero text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "FAQ", href: "/faq" },
      ]} />
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4 font-heading mt-6">
        ❓ Foire Aux Questions (FAQ)
      </h1>
      <p class="text-amber-200 text-lg max-w-2xl">
        Une question technique, administrative ou sur le budget ? Retrouvez les réponses exhaustives de nos experts chauffagistes.
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white rounded-2xl border border-amber-200 p-6 md:p-10 shadow-sm">
      <h2 class="text-2xl font-bold text-brand-800 mb-6 font-heading text-center">
        💡 Questions fréquentes sur le chauffage aux pellets
      </h2>
      <FAQ items={siteConfig.faq} />
    </div>

    <!-- Final CTA card -->
    <div class="cta-gradient rounded-2xl p-8 text-center text-white mt-12 shadow-lg">
      <h2 class="text-xl md:text-2xl font-bold mb-3 font-heading">
        Vous avez un projet d'installation ?
      </h2>
      <p class="text-green-100 mb-6 text-sm max-w-md mx-auto">
        Estimez gratuitement votre budget auprès de 3 installateurs certifiés RGE Qualibois près de chez vous.
      </p>
      <a href="/devis" class="inline-block bg-white text-accent-600 font-bold px-8 py-3.5 rounded-xl hover:bg-green-50 transition-all shadow-md">
        🔥 Demander mes devis gratuits
      </a>
    </div>
  </section>
</BaseLayout>
