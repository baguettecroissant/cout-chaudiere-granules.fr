<script>
  // Progressive Enhancement Client Script for instant search and filters
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('faq-search') as HTMLInputElement | null;
    const clearButton = document.getElementById('search-clear') as HTMLButtonElement | null;
    const searchStatus = document.getElementById('search-status') as HTMLParagraphElement | null;
    const emptyState = document.getElementById('faq-empty-state') as HTMLDivElement | null;
    const highlightSpan = document.getElementById('search-query-highlight') as HTMLSpanElement | null;
    const resetBtn = document.getElementById('faq-reset-btn') as HTMLButtonElement | null;
    const cards = document.querySelectorAll('.faq-card') as NodeListOf<HTMLDetailsElement>;
    const groupSections = document.querySelectorAll('.faq-group-section') as NodeListOf<HTMLDivElement>;
    const filterButtons = document.querySelectorAll('[data-filter]') as NodeListOf<HTMLButtonElement>;

    let currentCategory = 'all';
    let searchQuery = '';

    // Cache the original HTML content to prevent losing formatting and structure during regex replacement
    const originalTextCache = new Map<string, { q: string; a: string }>();
    cards.forEach(card => {
      const qText = card.querySelector('.faq-question-text');
      const aText = card.querySelector('.faq-answer-text');
      if (qText && aText) {
        originalTextCache.set(card.id, {
          q: qText.innerHTML,
          a: aText.innerHTML
        });
      }
    });

    // Strip HTML to get plain text for matching
    const stripHtml = (html: string) => {
      const doc = new DOMParser().parseFromString(html, 'text/html');
      return doc.body.textContent || "";
    };

    // Helper to highlight terms
    const highlight = (text: string, term: string) => {
      if (!term) return text;
      // Skip highlighting inside HTML tags to avoid breaking tags like <strong> or <ul>
      const escapedTerm = term.replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&');
      // Create a regex to match outside of tags
      const regex = new RegExp(`(${escapedTerm})`, 'gi');
      return text.replace(regex, '<mark class="bg-amber-200 text-brand-950 px-0.5 rounded font-semibold">$1</mark>');
    };

    const updateFaq = () => {
      let visibleCount = 0;
      const normalizedQuery = searchQuery.trim().toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");

      // Handle Clear Button display
      if (clearButton) {
        if (searchQuery.length > 0) {
          clearButton.classList.remove('hidden');
        } else {
          clearButton.classList.add('hidden');
        }
      }

      cards.forEach(card => {
        const cache = originalTextCache.get(card.id);
        const qTextEl = card.querySelector('.faq-question-text');
        const aTextEl = card.querySelector('.faq-answer-text');

        if (!cache || !qTextEl || !aTextEl) return;

        const categoryMatches = (currentCategory === 'all' || card.dataset.itemCat === currentCategory);
        
        const plainQ = stripHtml(cache.q).toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        const plainA = stripHtml(cache.a).toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        
        const searchMatches = !normalizedQuery || 
                              plainQ.includes(normalizedQuery) || 
                              plainA.includes(normalizedQuery);

        if (categoryMatches && searchMatches) {
          card.classList.remove('hidden');
          visibleCount++;

          if (normalizedQuery) {
            card.open = true; // Auto-open matching items during search
            // Highlight matching terms, but carefully to avoid breaking raw structure
            qTextEl.innerHTML = highlight(cache.q, searchQuery);
            aTextEl.innerHTML = highlight(cache.a, searchQuery);
          } else {
            card.open = false; // Close when search is empty
            qTextEl.innerHTML = cache.q;
            aTextEl.innerHTML = cache.a;
          }
        } else {
          card.classList.add('hidden');
          card.open = false;
          // Restore original state
          qTextEl.innerHTML = cache.q;
          aTextEl.innerHTML = cache.a;
        }
      });

      // Show/Hide category headers based on whether any cards inside them are visible
      groupSections.forEach(section => {
        const cat = section.dataset.catSection;
        // Count visible cards under this section
        const sectionVisibleCards = section.querySelectorAll('.faq-card:not(.hidden)').length;
        
        if (sectionVisibleCards > 0 && (currentCategory === 'all' || cat === currentCategory)) {
          section.classList.remove('hidden');
        } else {
          section.classList.add('hidden');
        }
      });

      // Handle empty state
      if (emptyState) {
        if (visibleCount === 0) {
          emptyState.classList.remove('hidden');
          if (highlightSpan) highlightSpan.textContent = searchQuery;
        } else {
          emptyState.classList.add('hidden');
        }
      }

      // Update Search status count message
      if (searchStatus) {
        if (searchQuery.trim().length > 0) {
          searchStatus.textContent = `${visibleCount} question${visibleCount > 1 ? 's' : ''} trouvée${visibleCount > 1 ? 's' : ''} pour votre recherche`;
          searchStatus.classList.remove('opacity-0');
        } else {
          searchStatus.classList.add('opacity-0');
          searchStatus.textContent = '';
        }
      }
    };

    // Category button click handlers
    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        currentCategory = btn.dataset.filter || 'all';

        // Update active styling
        filterButtons.forEach(b => {
          if (b.dataset.filter === currentCategory) {
            b.setAttribute('aria-selected', 'true');
            b.className = 'flex items-center gap-2 px-4 py-2 text-xs md:text-sm font-bold rounded-full border transition-all duration-200 shadow-sm cursor-pointer select-none bg-green-700 text-white border-green-700 ring-2 ring-green-700/20';
          } else {
            b.setAttribute('aria-selected', 'false');
            b.className = 'flex items-center gap-2 px-4 py-2 text-xs md:text-sm font-bold rounded-full border transition-all duration-200 shadow-sm cursor-pointer select-none bg-white text-brand-850 border-amber-200 hover:bg-amber-50 hover:border-amber-300';
          }
        });

        updateFaq();
      });
    });

    // Live Search events
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value;
        updateFaq();
      });
    }

    if (clearButton && searchInput) {
      clearButton.addEventListener('click', () => {
        searchInput.value = '';
        searchQuery = '';
        updateFaq();
        searchInput.focus();
      });
    }

    // Reset button on empty state
    if (resetBtn && searchInput) {
      resetBtn.addEventListener('click', () => {
        searchInput.value = '';
        searchQuery = '';
        // Reset category filter too
        const allBtn = document.querySelector('[data-filter="all"]') as HTMLButtonElement | null;
        if (allBtn) allBtn.click();
        updateFaq();
      });
    }
  });
</script>
