---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuoteWidget from '../../components/QuoteWidget.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { siteConfig } from '../../../site.config';
import { guides, type Guide } from '../../data/guides';

export function getStaticPaths() {
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props as { guide: Guide };
const relatedGuides = guides.filter(g => g.slug !== guide.slug).slice(0, 3);

const title = guide.metaTitle + " | " + siteConfig.name;
const description = guide.metaDescription;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": guide.title,
    "description": guide.metaDescription,
    "image": "https://" + siteConfig.domain + guide.image,
    "datePublished": guide.date + "T08:00:00+01:00",
    "author": {
      "@type": "Organization",
      "name": siteConfig.name
    },
    "publisher": {
      "@type": "Organization",
      "name": siteConfig.name,
      "logo": {
        "@type": "ImageObject",
        "url": "https://" + siteConfig.domain + "/favicon.svg"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://" + siteConfig.domain },
      { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://" + siteConfig.domain + "/guides" },
      { "@type": "ListItem", "position": 3, "name": guide.title },
    ]
  }
];
---

<BaseLayout title={title} description={description} canonical={"/guides/" + guide.slug} jsonLd={jsonLd}>
  <section class="gradient-hero text-white py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Guides", href: "/guides" },
        { label: guide.title, href: "/guides/" + guide.slug },
      ]} />

      <div class="grid lg:grid-cols-5 gap-10 items-start mt-6">
        <div class="lg:col-span-3">
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-1.5 rounded-full text-sm mb-4">
            <span>{guide.emoji}</span>
            <span>{guide.category} • Publié le {guide.date}</span>
          </div>

          <h1 class="text-3xl md:text-5xl font-extrabold leading-tight mb-4 font-heading">
            {guide.title}
          </h1>
          <p class="text-amber-200/80 leading-relaxed mb-6 max-w-xl text-sm md:text-base">
            {guide.excerpt}
          </p>

          <div class="inline-flex items-center gap-2 text-xs text-amber-200/60 font-semibold bg-white/5 px-3 py-1.5 rounded-md">
            <span>⏱️ Temps de lecture : {guide.readTime}</span>
          </div>
        </div>
        <div class="lg:col-span-2">
          <QuoteWidget keyword={guide.title} />
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid lg:grid-cols-12 gap-8 items-start">
      <!-- Article Content -->
      <article class="lg:col-span-8 bg-white rounded-2xl border border-amber-200 shadow-sm p-6 md:p-10 prose prose-amber max-w-none text-brand-700 leading-relaxed">
        <img src={guide.image} alt={guide.title} class="w-full h-80 object-cover rounded-2xl mb-8 border border-amber-100 shadow-sm" />
        <div set:html={guide.content} />
      </article>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 space-y-6">
        <!-- Devis CTA -->
        <div class="cta-gradient rounded-2xl p-6 text-white text-center shadow-lg lg:sticky lg:top-24">
          <h3 class="text-base font-bold mb-3 font-heading">Recevez 3 Devis Gratuits</h3>
          <p class="text-xs text-green-100 mb-4">Artisans certifiés RGE Qualibois. Réponse en 48h.</p>
          <a href="/devis" class="inline-block bg-white text-accent-700 font-bold px-6 py-3 rounded-xl hover:bg-green-50 transition-colors text-sm shadow-md">
            🔥 Demander mes devis →
          </a>
        </div>

        <!-- Quick links: Marques -->
        <div class="bg-white rounded-2xl border border-amber-200 p-5 shadow-sm">
          <h3 class="text-sm font-bold text-brand-800 mb-3 font-heading">🏆 Marques à découvrir</h3>
          <ul class="space-y-2">
            <li><a href="/marques/okofen" class="text-xs text-brand-700 hover:text-accent-500 transition-colors">🇦🇹 Ökofen — Premium</a></li>
            <li><a href="/marques/froling" class="text-xs text-brand-700 hover:text-accent-500 transition-colors">🇦🇹 Fröling — Pro</a></li>
            <li><a href="/marques/hargassner" class="text-xs text-brand-700 hover:text-accent-500 transition-colors">🇦🇹 Hargassner — Robuste</a></li>
            <li><a href="/marques/de-dietrich" class="text-xs text-brand-700 hover:text-accent-500 transition-colors">🇫🇷 De Dietrich — SAV France</a></li>
            <li><a href="/marques/viessmann" class="text-xs text-brand-700 hover:text-accent-500 transition-colors">🇩🇪 Viessmann — Connecté</a></li>
            <li><a href="/marques/hs-france" class="text-xs text-brand-700 hover:text-accent-500 transition-colors">🇫🇷 HS France — Budget</a></li>
          </ul>
          <a href="/marques" class="block text-center text-accent-500 hover:text-accent-600 font-semibold text-xs mt-3 transition-colors">Comparatif complet →</a>
        </div>

        <!-- Quick links: Simulateur -->
        <a href="/simulateur-prix" class="block bg-brand-700 text-white rounded-2xl border border-brand-800 p-5 hover:bg-brand-600 transition-all group shadow-md">
          <span class="text-xl block mb-1">🧮</span>
          <h3 class="font-bold text-sm text-amber-300 group-hover:text-amber-200">Simulateur de prix</h3>
          <p class="text-xs text-amber-200/80 mt-1">Estimez votre reste à charge en 2 min.</p>
        </a>

        <!-- Related guides -->
        <div class="bg-white rounded-2xl border border-amber-200 p-5 shadow-sm">
          <h3 class="text-sm font-bold text-brand-800 mb-3 font-heading">📚 Guides liés</h3>
          <div class="space-y-3">
            {relatedGuides.map((g) => (
              <a href={`/guides/${g.slug}`} class="flex gap-3 group hover:bg-brand-50 rounded-lg p-2 -mx-2 transition-colors">
                <span class="text-base">{g.emoji}</span>
                <div>
                  <span class="block text-xs font-bold text-brand-800 group-hover:text-accent-500 leading-snug">{g.title}</span>
                  <span class="block text-xs text-brand-600 mt-0.5">{g.readTime}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>

    <!-- Bottom cross-links (full width) -->
    <div class="mt-12 space-y-6">
      <!-- Popular cities -->
      <section>
        <h2 class="text-xl font-bold text-brand-800 mb-4 font-heading">📍 Prix chaudière granulés par ville</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-8 gap-3">
          <a href="/prix-chaudiere-granules/paris" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Paris</span></a>
          <a href="/prix-chaudiere-granules/lyon" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Lyon</span></a>
          <a href="/prix-chaudiere-granules/bordeaux" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Bordeaux</span></a>
          <a href="/prix-chaudiere-granules/toulouse" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Toulouse</span></a>
          <a href="/prix-chaudiere-granules/strasbourg" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Strasbourg</span></a>
          <a href="/prix-chaudiere-granules/marseille" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Marseille</span></a>
          <a href="/prix-chaudiere-granules/nantes" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Nantes</span></a>
          <a href="/prix-chaudiere-granules/lille" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Lille</span></a>
        </div>
        <div class="text-center mt-4">
          <a href="/annuaire" class="text-accent-500 hover:text-accent-600 font-semibold text-sm transition-colors">Annuaire complet →</a>
        </div>
      </section>

      <!-- FAQ + Glossaire -->
      <section class="grid sm:grid-cols-2 gap-4">
        <a href="/faq" class="bg-white rounded-2xl border border-amber-200 p-6 hover:border-accent-400 hover:shadow-md transition-all group">
          <span class="text-2xl block mb-2">❓</span>
          <h3 class="font-bold text-lg font-heading text-brand-800 group-hover:text-accent-500">FAQ Complète</h3>
          <p class="text-xs text-brand-600 mt-2">Réponses d'experts sur le prix, les aides et l'installation.</p>
        </a>
        <a href="/glossaire" class="bg-white rounded-2xl border border-amber-200 p-6 hover:border-accent-400 hover:shadow-md transition-all group">
          <span class="text-2xl block mb-2">📖</span>
          <h3 class="font-bold text-lg font-heading text-brand-800 group-hover:text-accent-500">Glossaire Technique</h3>
          <p class="text-xs text-brand-600 mt-2">Tous les termes techniques expliqués simplement.</p>
        </a>
      </section>
    </div>
  </div>
</BaseLayout>

