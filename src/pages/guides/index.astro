---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../site.config';
import { guides } from '../../data/guides';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Guides et Conseils Chaudière à Granulés",
    "description": "Retrouvez l'ensemble de nos guides rédigés par nos experts pour tout comprendre sur la chaudière à granulés : prix, aides financières, entretien et fonctionnement.",
    "url": "https://" + siteConfig.domain + "/guides",
  }
];
---

<BaseLayout
  title={`Guides & Conseils Experts Chaudière Granulés 2026 | ${siteConfig.name}`}
  description={`Tous nos guides pratiques sur la chaudière à granulés de bois : estimations de prix, calcul des aides de l'État, installation et maintenance.`}
  canonical="/guides"
  jsonLd={jsonLd}
>
  <section class="gradient-hero text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Guides", href: "/guides" },
      ]} />
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4 font-heading mt-6">
        📚 Guides & Conseils Techniques 2026
      </h1>
      <p class="text-amber-200 text-lg max-w-2xl">
        Informez-vous en détail sur la chaudière biomasse grâce à nos articles rédigés par des experts certifiés RGE.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {guides.map((g) => (
        <div class="bg-white rounded-2xl border border-amber-200 shadow-sm overflow-hidden flex flex-col justify-between card-hover">
          <div>
            <!-- Image of guide -->
            <img src={g.image} alt={g.title} class="w-full h-48 object-cover border-b border-amber-100" />
            
            <div class="p-6 space-y-3">
              <div class="flex justify-between items-center text-xs">
                <span class="font-semibold text-brand-600 uppercase tracking-wider bg-brand-50 px-2 py-0.5 rounded">
                  {g.category}
                </span>
                <span class="text-brand-600 font-data font-semibold">
                  ⏱️ {g.readTime}
                </span>
              </div>

              <!-- Title -->
              <h2 class="text-xl font-bold text-brand-800 font-heading leading-tight line-clamp-2">
                {g.title}
              </h2>

              <!-- Excerpt -->
              <p class="text-xs text-brand-700 leading-relaxed line-clamp-3">
                {g.excerpt}
              </p>
            </div>
          </div>

          <div class="bg-amber-50/30 p-5 border-t border-amber-100 flex items-center justify-between">
            <span class="text-xs text-brand-600 font-medium">Publié le {g.date}</span>
            <a href={`/guides/${g.slug}`} class="cta-gradient text-white text-xs font-bold px-4 py-2 rounded-lg shadow-sm hover:shadow-md transition-all">
              Lire l'article →
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Cross-links: Marques -->
    <div class="mt-12">
      <h2 class="text-xl font-bold text-brand-800 mb-4 font-heading">🏆 Marques populaires</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-3">
        <a href="/marques/okofen" class="bg-white border border-amber-200 rounded-xl px-4 py-3 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-sm">Ökofen</span></a>
        <a href="/marques/froling" class="bg-white border border-amber-200 rounded-xl px-4 py-3 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-sm">Fröling</span></a>
        <a href="/marques/hargassner" class="bg-white border border-amber-200 rounded-xl px-4 py-3 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-sm">Hargassner</span></a>
        <a href="/marques/de-dietrich" class="bg-white border border-amber-200 rounded-xl px-4 py-3 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-sm">De Dietrich</span></a>
        <a href="/marques/viessmann" class="bg-white border border-amber-200 rounded-xl px-4 py-3 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-sm">Viessmann</span></a>
        <a href="/marques/hs-france" class="bg-white border border-amber-200 rounded-xl px-4 py-3 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-sm">HS France</span></a>
      </div>
    </div>

    <!-- Cross-links: Simulateur + FAQ -->
    <div class="mt-6 grid sm:grid-cols-2 gap-4">
      <a href="/simulateur-prix" class="bg-brand-700 text-white rounded-2xl border border-brand-800 p-6 hover:bg-brand-600 transition-all group shadow-md">
        <span class="text-2xl block mb-2">🧮</span>
        <h3 class="font-bold text-lg font-heading text-amber-300 group-hover:text-amber-200">Simulateur de prix</h3>
        <p class="text-xs text-amber-200/80 mt-2">Estimez votre budget et vos aides en 2 minutes.</p>
      </a>
      <a href="/faq" class="bg-white rounded-2xl border border-amber-200 p-6 hover:border-accent-400 hover:shadow-md transition-all group">
        <span class="text-2xl block mb-2">❓</span>
        <h3 class="font-bold text-lg font-heading text-brand-800 group-hover:text-accent-500">FAQ Complète</h3>
        <p class="text-xs text-brand-600 mt-2">Réponses d'experts sur le prix, les aides et l'installation.</p>
      </a>
    </div>
  </section>
</BaseLayout>

