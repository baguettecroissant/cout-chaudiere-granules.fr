---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuoteWidget from '../../components/QuoteWidget.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { siteConfig } from '../../../site.config';
import { brands, type Brand } from '../../data/brands';

export function getStaticPaths() {
  return brands.map(brand => ({
    params: { slug: brand.slug },
    props: { brand },
  }));
}

const { brand } = Astro.props as { brand: Brand };

const title = "Chaudière " + brand.name + " : Prix, Gamme & Avis 2026";
const description = brand.description;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Chaudière à granulés " + brand.name,
    "description": brand.description,
    "brand": {
      "@type": "Brand",
      "name": brand.name
    },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "EUR",
      "lowPrice": brand.models[0]?.price.split(' – ')[0]?.replace(/\s/g, '') || "8000",
      "highPrice": brand.models[brand.models.length - 1]?.price.split(' – ')[1]?.replace(/\s/g, '')?.replace('€', '') || "20000"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://" + siteConfig.domain },
      { "@type": "ListItem", "position": 2, "name": "Marques", "item": "https://" + siteConfig.domain + "/marques" },
      { "@type": "ListItem", "position": 3, "name": brand.name },
    ]
  }
];
---

<BaseLayout title={title} description={description} canonical={"/marques/" + brand.slug} jsonLd={jsonLd}>
  <section class="gradient-hero text-white py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Marques", href: "/marques" },
        { label: brand.name, href: "/marques/" + brand.slug },
      ]} />

      <div class="grid lg:grid-cols-5 gap-10 items-start mt-6">
        <div class="lg:col-span-3">
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-1.5 rounded-full text-sm mb-4">
            <span>{brand.flag}</span>
            <span>Fabrication {brand.country}</span>
          </div>

          <h1 class="text-3xl md:text-5xl font-extrabold leading-tight mb-4 font-heading">
            Chaudière {brand.name} : Prix, Modèles & Avis 2026
          </h1>
          <p class="text-amber-200/80 leading-relaxed mb-6 max-w-xl text-sm md:text-base">
            {brand.description}
          </p>

          <a href="#devis-form" class="inline-block cta-gradient text-white font-bold px-6 py-3.5 rounded-xl transition-all shadow-lg text-base">
            🔥 Obtenir des Devis {brand.name}
          </a>
        </div>
        <div class="lg:col-span-2">
          <QuoteWidget keyword={"Chaudière " + brand.name} />
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12">
    <!-- Brand Content Review -->
    <section class="prose prose-amber max-w-none text-brand-700 space-y-4">
      <div set:html={brand.content} />
    </section>

    <!-- Models Table -->
    <section class="bg-white rounded-2xl border border-amber-200 p-6 md:p-8 shadow-sm">
      <h2 class="text-xl md:text-2xl font-bold text-brand-800 mb-4 font-heading">
        📋 Modèles phares & tarifs indicatifs de {brand.name}
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm price-table border-collapse rounded-xl overflow-hidden">
          <thead>
            <tr>
              <th class="px-4 py-3 text-left">Modèle</th>
              <th class="px-4 py-3 text-left">Puissance</th>
              <th class="px-4 py-3 text-left">Rendement</th>
              <th class="px-4 py-3 text-left">Prix Indicatif (Achat seul)</th>
              <th class="px-4 py-3 text-left">Spécificités</th>
            </tr>
          </thead>
          <tbody>
            {brand.models.map(m => (
              <tr class="border-b border-amber-100">
                <td class="px-4 py-4 font-bold text-brand-800">{m.name}</td>
                <td class="px-4 py-4 font-data text-brand-600 text-xs">{m.power}</td>
                <td class="px-4 py-4 font-data font-semibold text-brand-700">{m.rendement}</td>
                <td class="px-4 py-4 price font-data font-bold text-accent-500">{m.price}</td>
                <td class="px-4 py-4 text-xs text-brand-600 leading-relaxed">{m.features}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Pros & Cons -->
    <section class="grid md:grid-cols-2 gap-6">
      <div class="bg-green-50/50 border border-green-200 rounded-2xl p-6 md:p-8">
        <h3 class="text-lg font-bold text-green-800 mb-4 flex items-center gap-2 font-heading">
          🟢 Points forts de {brand.name}
        </h3>
        <ul class="space-y-2 text-xs text-brand-700">
          {brand.pros.map(pro => (
            <li class="flex items-start gap-2">
              <span class="text-green-600 font-bold">✓</span>
              <span>{pro}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-red-50/30 border border-red-100 rounded-2xl p-6 md:p-8">
        <h3 class="text-lg font-bold text-red-800 mb-4 flex items-center gap-2 font-heading">
          🔴 Points faibles
        </h3>
        <ul class="space-y-2 text-xs text-brand-700">
          {brand.cons.map(con => (
            <li class="flex items-start gap-2">
              <span class="text-red-500 font-bold">⚠</span>
              <span>{con}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Warranty & SAV -->
    <section class="bg-brand-50 rounded-2xl border border-amber-200 p-6 md:p-8 grid md:grid-cols-2 gap-6">
      <div>
        <h3 class="text-lg font-bold text-brand-800 mb-2 font-heading">🛡️ Garantie Constructeur</h3>
        <p class="text-xs text-brand-700 leading-relaxed">{brand.warranty}</p>
      </div>
      <div>
        <h3 class="text-lg font-bold text-brand-800 mb-2 font-heading">🛠️ Réseau SAV en France</h3>
        <p class="text-xs text-brand-700 leading-relaxed">{brand.sav}</p>
      </div>
    </section>
  </div>
</BaseLayout>
