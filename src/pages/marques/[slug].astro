---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuoteWidget from '../../components/QuoteWidget.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { siteConfig } from '../../../site.config';
import { brands, type Brand } from '../../data/brands';

export function getStaticPaths() {
  return brands.map(brand => ({
    params: { slug: brand.slug },
    props: { brand },
  }));
}

const { brand } = Astro.props as { brand: Brand };

const title = "Chaudière " + brand.name + " : Prix, Gamme & Avis 2026";
const description = brand.description;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Chaudière à granulés " + brand.name,
    "description": brand.description,
    "brand": {
      "@type": "Brand",
      "name": brand.name
    },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "EUR",
      "lowPrice": brand.models[0]?.price.split(' – ')[0]?.replace(/\s/g, '') || "8000",
      "highPrice": brand.models[brand.models.length - 1]?.price.split(' – ')[1]?.replace(/\s/g, '')?.replace('€', '') || "20000"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://" + siteConfig.domain },
      { "@type": "ListItem", "position": 2, "name": "Marques", "item": "https://" + siteConfig.domain + "/marques" },
      { "@type": "ListItem", "position": 3, "name": brand.name },
    ]
  }
];
---

<BaseLayout title={title} description={description} canonical={"/marques/" + brand.slug} jsonLd={jsonLd}>
  <section class="gradient-hero text-white py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Marques", href: "/marques" },
        { label: brand.name, href: "/marques/" + brand.slug },
      ]} />

      <div class="grid lg:grid-cols-5 gap-10 items-start mt-6">
        <div class="lg:col-span-3">
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-1.5 rounded-full text-sm mb-4">
            <span>{brand.flag}</span>
            <span>Fabrication {brand.country}</span>
          </div>

          <h1 class="text-3xl md:text-5xl font-extrabold leading-tight mb-4 font-heading">
            Chaudière {brand.name} : Prix, Modèles & Avis 2026
          </h1>
          <p class="text-amber-200/80 leading-relaxed mb-6 max-w-xl text-sm md:text-base">
            {brand.description}
          </p>

          <a href="#devis-form" class="inline-block cta-gradient text-white font-bold px-6 py-3.5 rounded-xl transition-all shadow-lg text-base">
            🔥 Obtenir des Devis {brand.name}
          </a>
        </div>
        <div class="lg:col-span-2">
          <QuoteWidget keyword={"Chaudière " + brand.name} />
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12">
    <!-- Brand Content Review -->
    <section class="prose prose-amber max-w-none text-brand-700 space-y-4">
      <div set:html={brand.content} />
    </section>

    <!-- Models Table -->
    <section class="bg-white rounded-2xl border border-amber-200 p-6 md:p-8 shadow-sm">
      <h2 class="text-xl md:text-2xl font-bold text-brand-800 mb-4 font-heading">
        📋 Modèles phares & tarifs indicatifs de {brand.name}
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm price-table border-collapse rounded-xl overflow-hidden">
          <thead>
            <tr>
              <th class="px-4 py-3 text-left">Modèle</th>
              <th class="px-4 py-3 text-left">Puissance</th>
              <th class="px-4 py-3 text-left">Rendement</th>
              <th class="px-4 py-3 text-left">Prix Indicatif (Achat seul)</th>
              <th class="px-4 py-3 text-left">Spécificités</th>
            </tr>
          </thead>
          <tbody>
            {brand.models.map(m => (
              <tr class="border-b border-amber-100">
                <td class="px-4 py-4 font-bold text-brand-800">{m.name}</td>
                <td class="px-4 py-4 font-data text-brand-600 text-xs">{m.power}</td>
                <td class="px-4 py-4 font-data font-semibold text-brand-700">{m.rendement}</td>
                <td class="px-4 py-4 price font-data font-bold text-accent-500">{m.price}</td>
                <td class="px-4 py-4 text-xs text-brand-600 leading-relaxed">{m.features}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Pros & Cons -->
    <section class="grid md:grid-cols-2 gap-6">
      <div class="bg-green-50/50 border border-green-200 rounded-2xl p-6 md:p-8">
        <h3 class="text-lg font-bold text-green-800 mb-4 flex items-center gap-2 font-heading">
          🟢 Points forts de {brand.name}
        </h3>
        <ul class="space-y-2 text-xs text-brand-700">
          {brand.pros.map(pro => (
            <li class="flex items-start gap-2">
              <span class="text-green-600 font-bold">✓</span>
              <span>{pro}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-red-50/30 border border-red-100 rounded-2xl p-6 md:p-8">
        <h3 class="text-lg font-bold text-red-800 mb-4 flex items-center gap-2 font-heading">
          🔴 Points faibles
        </h3>
        <ul class="space-y-2 text-xs text-brand-700">
          {brand.cons.map(con => (
            <li class="flex items-start gap-2">
              <span class="text-red-500 font-bold">⚠</span>
              <span>{con}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Warranty & SAV -->
    <section class="bg-brand-50 rounded-2xl border border-amber-200 p-6 md:p-8 grid md:grid-cols-2 gap-6">
      <div>
        <h3 class="text-lg font-bold text-brand-800 mb-2 font-heading">🛡️ Garantie Constructeur</h3>
        <p class="text-xs text-brand-700 leading-relaxed">{brand.warranty}</p>
      </div>
      <div>
        <h3 class="text-lg font-bold text-brand-800 mb-2 font-heading">🛠️ Réseau SAV en France</h3>
        <p class="text-xs text-brand-700 leading-relaxed">{brand.sav}</p>
      </div>
    </section>

    <!-- Other brands -->
    <section>
      <h2 class="text-xl font-bold text-brand-800 mb-4 font-heading">🏆 Comparer avec d'autres marques</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
        {brands.filter(b => b.slug !== brand.slug).map((b) => (
          <a href={`/marques/${b.slug}`} class="bg-white border border-amber-200 rounded-xl px-4 py-4 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover">
            <span class="text-xl block mb-1">{b.flag}</span>
            <span class="font-semibold text-brand-800 group-hover:text-accent-500 text-sm block">{b.name}</span>
            <span class="text-xs text-brand-600 mt-0.5 block">{b.priceRange}</span>
          </a>
        ))}
      </div>
      <div class="text-center mt-4">
        <a href="/marques" class="text-accent-500 hover:text-accent-600 font-semibold text-sm transition-colors">Comparatif complet des marques →</a>
      </div>
    </section>

    <!-- Related guides -->
    <section class="bg-white rounded-2xl shadow-sm border border-amber-200 p-6 md:p-8">
      <h2 class="text-xl font-bold text-brand-800 mb-4 font-heading">📚 Guides liés</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <a href="/guides/prix-chaudiere-granules-2026" class="bg-brand-50 rounded-xl p-4 border border-amber-100 hover:border-accent-400 hover:shadow-md transition-all group">
          <span class="text-lg block mb-1">💰</span>
          <span class="font-bold text-brand-800 group-hover:text-accent-500 text-sm block">Prix Chaudière Granulés 2026</span>
          <span class="text-xs text-brand-600 mt-1 block">Budget complet fourniture + pose</span>
        </a>
        <a href="/guides/comparatif-marques-chaudiere-granules" class="bg-brand-50 rounded-xl p-4 border border-amber-100 hover:border-accent-400 hover:shadow-md transition-all group">
          <span class="text-lg block mb-1">⭐</span>
          <span class="font-bold text-brand-800 group-hover:text-accent-500 text-sm block">Comparatif Marques 2026</span>
          <span class="text-xs text-brand-600 mt-1 block">Ökofen vs Fröling vs Hargassner</span>
        </a>
        <a href="/guides/aides-chaudiere-granules-2026" class="bg-brand-50 rounded-xl p-4 border border-amber-100 hover:border-accent-400 hover:shadow-md transition-all group">
          <span class="text-lg block mb-1">🏛️</span>
          <span class="font-bold text-brand-800 group-hover:text-accent-500 text-sm block">Aides MaPrimeRénov' 2026</span>
          <span class="text-xs text-brand-600 mt-1 block">Cumul des aides et reste à charge</span>
        </a>
      </div>
      <div class="text-center mt-4">
        <a href="/guides" class="text-accent-500 hover:text-accent-600 font-semibold text-sm transition-colors">Tous les guides →</a>
      </div>
    </section>

    <!-- Popular cities -->
    <section>
      <h2 class="text-xl font-bold text-brand-800 mb-4 font-heading">📍 Prix par ville</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-8 gap-3">
        <a href="/prix-chaudiere-granules/paris" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Paris</span></a>
        <a href="/prix-chaudiere-granules/lyon" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Lyon</span></a>
        <a href="/prix-chaudiere-granules/bordeaux" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Bordeaux</span></a>
        <a href="/prix-chaudiere-granules/toulouse" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Toulouse</span></a>
        <a href="/prix-chaudiere-granules/strasbourg" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Strasbourg</span></a>
        <a href="/prix-chaudiere-granules/marseille" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Marseille</span></a>
        <a href="/prix-chaudiere-granules/nantes" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Nantes</span></a>
        <a href="/prix-chaudiere-granules/lille" class="bg-white border border-amber-200 rounded-xl px-3 py-2.5 hover:border-accent-400 hover:shadow-md transition-all group text-center card-hover"><span class="font-semibold text-brand-800 group-hover:text-accent-500 text-xs">Lille</span></a>
      </div>
      <div class="text-center mt-4">
        <a href="/annuaire" class="text-accent-500 hover:text-accent-600 font-semibold text-sm transition-colors">Annuaire complet →</a>
      </div>
    </section>

    <!-- Simulator CTA -->
    <section>
      <a href="/simulateur-prix" class="block bg-brand-700 text-white rounded-2xl border border-brand-800 p-6 md:p-8 hover:bg-brand-600 transition-all group shadow-md text-center">
        <span class="text-3xl block mb-2">🧮</span>
        <h3 class="font-bold text-xl font-heading text-amber-300 group-hover:text-amber-200">Simulez votre projet {brand.name}</h3>
        <p class="text-sm text-amber-200/80 mt-2 max-w-lg mx-auto">Estimez la puissance nécessaire, le coût total et le montant de vos aides pour une chaudière {brand.name}.</p>
        <span class="inline-block mt-4 bg-white text-accent-600 font-bold px-6 py-3 rounded-xl shadow text-sm">⚡ Lancer le simulateur gratuit →</span>
      </a>
    </section>
  </div>
</BaseLayout>
