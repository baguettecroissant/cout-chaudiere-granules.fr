---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../site.config';
import { brands } from '../../data/brands';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Marques de Chaudières à Granulés de Bois",
    "description": "Retrouvez notre comparatif complet des marques de chaudières à granulés : Ökofen, Fröling, Hargassner, De Dietrich, Viessmann et HS France.",
    "url": "https://" + siteConfig.domain + "/marques",
  }
];
---

<BaseLayout
  title={`Comparatif Marques Chaudière Granulés 2026 : Prix & Avis | ${siteConfig.name}`}
  description={`Quelle est la meilleure marque de chaudière à granulés ? Ökofen, Fröling, Hargassner, De Dietrich ou Viessmann ? Comparatif des gammes, prix et garanties.`}
  canonical="/marques"
  jsonLd={jsonLd}
>
  <section class="gradient-hero text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Marques", href: "/marques" },
      ]} />
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4 font-heading mt-6">
        🏆 Comparatif Marques Chaudière Granulés 2026
      </h1>
      <p class="text-amber-200 text-lg max-w-2xl">
        Sélectionnez le fabricant idéal selon vos contraintes d'espace, de puissance thermique et votre budget.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {brands.map((b) => (
        <div class="bg-white rounded-2xl border border-amber-200 shadow-sm overflow-hidden flex flex-col justify-between card-hover">
          <div class="p-6 space-y-4">
            <!-- Brand Badge -->
            <div class="flex justify-between items-center">
              <span class="text-xs font-semibold text-brand-600 uppercase tracking-wider bg-brand-50 px-2.5 py-1 rounded-md">
                {b.positioning}
              </span>
              <span class="text-xs font-medium text-brand-600 flex items-center gap-1">
                {b.flag} {b.country}
              </span>
            </div>

            <!-- Title -->
            <h2 class="text-2xl font-bold text-brand-800 font-heading">
              Chaudière {b.name}
            </h2>

            <!-- Excerpt -->
            <p class="text-xs text-brand-700 leading-relaxed line-clamp-3">
              {b.description}
            </p>

            <!-- Metadata info -->
            <div class="bg-brand-50 p-3.5 rounded-xl text-xs space-y-1.5 border border-amber-100/50">
              <div class="flex justify-between">
                <span class="text-brand-600">Modèle phare :</span>
                <span class="font-bold text-brand-800">{b.flagship}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-brand-600">Tarif moyen posé :</span>
                <span class="font-bold text-accent-500 font-data">{b.priceRange}</span>
              </div>
            </div>
          </div>

          <div class="bg-amber-50/30 p-5 border-t border-amber-100 flex items-center justify-between">
            <span class="text-xs text-brand-600 font-semibold">Garantie : {b.warranty.split(',')[0]}</span>
            <a href={`/marques/${b.slug}`} class="cta-gradient text-white text-xs font-bold px-4 py-2 rounded-lg shadow-sm hover:shadow-md transition-all">
              Avis complet →
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Cross-links: Guides -->
    <div class="mt-12 bg-white rounded-2xl border border-amber-200 p-6 md:p-8 shadow-sm">
      <h2 class="text-xl font-bold text-brand-800 mb-4 font-heading">📚 Guides liés</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <a href="/guides/comparatif-marques-chaudiere-granules" class="bg-brand-50 rounded-xl p-4 border border-amber-100 hover:border-accent-400 hover:shadow-md transition-all group">
          <span class="text-lg block mb-1">⭐</span>
          <span class="font-bold text-brand-800 group-hover:text-accent-500 text-sm block">Comparatif Détaillé des Marques</span>
        </a>
        <a href="/guides/prix-chaudiere-granules-2026" class="bg-brand-50 rounded-xl p-4 border border-amber-100 hover:border-accent-400 hover:shadow-md transition-all group">
          <span class="text-lg block mb-1">💰</span>
          <span class="font-bold text-brand-800 group-hover:text-accent-500 text-sm block">Prix Complets 2026</span>
        </a>
        <a href="/guides/aides-chaudiere-granules-2026" class="bg-brand-50 rounded-xl p-4 border border-amber-100 hover:border-accent-400 hover:shadow-md transition-all group">
          <span class="text-lg block mb-1">🏛️</span>
          <span class="font-bold text-brand-800 group-hover:text-accent-500 text-sm block">Aides MaPrimeRénov'</span>
        </a>
      </div>
    </div>

    <!-- Cross-links: Simulateur + FAQ -->
    <div class="mt-6 grid sm:grid-cols-2 gap-4">
      <a href="/simulateur-prix" class="bg-brand-700 text-white rounded-2xl border border-brand-800 p-6 hover:bg-brand-600 transition-all group shadow-md">
        <span class="text-2xl block mb-2">🧮</span>
        <h3 class="font-bold text-lg font-heading text-amber-300 group-hover:text-amber-200">Simulateur de prix</h3>
        <p class="text-xs text-amber-200/80 mt-2">Estimez votre budget et vos aides.</p>
      </a>
      <a href="/faq" class="bg-white rounded-2xl border border-amber-200 p-6 hover:border-accent-400 hover:shadow-md transition-all group">
        <span class="text-2xl block mb-2">❓</span>
        <h3 class="font-bold text-lg font-heading text-brand-800 group-hover:text-accent-500">FAQ Complète</h3>
        <p class="text-xs text-brand-600 mt-2">Réponses d'experts sur le prix, les aides et l'installation.</p>
      </a>
    </div>
  </section>
</BaseLayout>

