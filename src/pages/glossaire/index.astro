---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../site.config';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const terms = [
  {
    letter: "A",
    word: "Aspiration (Alimentation par)",
    definition: "Système d'alimentation automatique déporté qui aspire les granulés depuis un silo de stockage éloigné (jusqu'à 20 mètres) vers la trémie intermédiaire de la chaudière à l'aide d'un moteur d'aspiration pneumatique. Offre une flexibilité d'implantation optimale."
  },
  {
    letter: "B",
    word: "Ballon ECS",
    definition: "Ballon d'Eau Chaude Sanitaire connecté à la chaudière à granulés. Il permet de produire l'eau chaude pour la cuisine et la salle de bain en utilisant la chaleur économique du bois."
  },
  {
    letter: "B",
    word: "Ballon tampon",
    definition: "Grand réservoir d'eau isolée qui stocke l'excès de chaleur produite par la chaudière et la restitue progressivement dans le circuit de chauffage. Il évite le fonctionnement en cycles courts (on/off), optimise le rendement et augmente la durée de vie du matériel."
  },
  {
    letter: "C",
    word: "CEE (Certificats d'Économies d'Énergie)",
    definition: "Primes financières financées par les fournisseurs d'énergie (les 'obligés') dans le cadre de la transition énergétique. Elles sont cumulables avec MaPrimeRénov' et attribuées sans condition de ressources pour l'installation d'équipements biomasse."
  },
  {
    letter: "D",
    word: "DINplus",
    definition: "Certification allemande pour les granulés de bois de haute qualité. Elle garantit un pouvoir calorifique élevé (>= 4,6 kWh/kg), un taux de cendres très bas (< 0,7%) et une humidité inférieure à 10%."
  },
  {
    letter: "E",
    word: "Éco-PTZ (Éco-Prêt à Taux Zéro)",
    definition: "Prêt bancaire à taux d'intérêt nul (0%) accordé par l'État pour financer des travaux de rénovation énergétique, comme le reste à charge d'une chaudière à granulés, à hauteur de 30 000€ maximum remboursable sur 15 ans."
  },
  {
    letter: "E",
    word: "ENplus A1",
    definition: "Norme européenne de certification de qualité des granulés de bois, équivalente et complémentaire à la norme DINplus. Elle contrôle toute la chaîne d'approvisionnement, de la production à la livraison."
  },
  {
    letter: "G",
    word: "Granulés de bois (Pellets)",
    definition: "Petits cylindres combustibles de 6 mm de diamètre et 10 à 45 mm de long, fabriqués par haute compression de sciures et copeaux de bois non traités, sans colle ni additif chimique. Combustible 100% renouvelable à haute densité énergétique."
  },
  {
    letter: "M",
    word: "MaPrimeRénov'",
    definition: "Principale aide publique de l'État français pour la rénovation énergétique des logements. Distribuée par l'Anah, elle propose des primes jusqu'à 10 000€ pour une chaudière à granulés en 2026 selon le profil de revenus du foyer."
  },
  {
    letter: "P",
    word: "PCI (Pouvoir Calorifique Inférieur)",
    definition: "Quantité totale de chaleur dégagée par la combustion complète d'une unité de combustible, sans prendre en compte l'énergie contenue dans la vapeur d'eau des fumées. C'est l'unité de mesure de référence pour la majorité des chaudières."
  },
  {
    letter: "P",
    word: "PCS (Pouvoir Calorifique Supérieur)",
    definition: "Quantité totale de chaleur dégagée par la combustion d'une unité de combustible, en comptant la récupération de l'énergie thermique contenue dans la vapeur d'eau des fumées. Base de fonctionnement de la condensation."
  },
  {
    letter: "R",
    word: "Rendement de condensation",
    definition: "Rendement d'une chaudière qui récupère l'énergie de la condensation de la vapeur d'eau des fumées. Les chaudières à granulés à condensation atteignent ainsi un rendement exceptionnel supérieur à 100% (jusqu'à 107% PCI)."
  },
  {
    letter: "R",
    word: "RGE (Reconnu Garant de l'Environnement)",
    definition: "Label de qualification professionnelle accordé aux entreprises du bâtiment spécialisées dans l'efficacité énergétique. Faire appel à un installateur certifié RGE (Qualibois dans le cas des granulés) est une condition obligatoire pour bénéficier des aides de l'État."
  },
  {
    letter: "S",
    word: "Silo textile",
    definition: "Réservoir de stockage souple fabriqué dans une toile synthétique ultra-résistante, étanche et anti-statique, montée sur une structure métallique. Très facile à installer dans un garage ou une cave, il contient de 1,5 à 5 tonnes de pellets."
  },
  {
    letter: "S",
    word: "Silo maçonné",
    definition: "Pièce ou espace technique construit en dur (maçonnerie) avec des pans inclinés (en bois ou béton) pour stocker les granulés de bois en vrac et les acheminer vers le centre par gravité."
  },
  {
    letter: "S",
    word: "Sonde Lambda",
    definition: "Capteur électronique installé dans le conduit d'évacuation des fumées. Elle mesure en temps réel le taux d'oxygène résiduel et permet à la chaudière d'ajuster en continu l'apport en air et en granulés pour une combustion parfaite."
  },
  {
    letter: "V",
    word: "Vis sans fin",
    definition: "Axe hélicoïdal métallique (comme un tire-bouchon géant) qui tourne lentement à l'intérieur d'un tube pour convoyer les granulés depuis le fond du silo vers le brûleur de la chaudière de manière automatique et dosée."
  }
];

const alphabet = ["A", "B", "C", "D", "E", "G", "M", "P", "R", "S", "V"];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Glossaire Technique de la Chaudière à Granulés de Bois",
    "description": "Lexique complet des termes techniques du chauffage à granulés (pellets, PCI, PCS, silo, vis sans fin, RGE, CEE, MaPrimeRénov').",
    "url": `https://${siteConfig.domain}/glossaire`,
  }
];
---

<BaseLayout
  title={`Glossaire Technique Chaudière Granulés | ${siteConfig.name}`}
  description={`Découvrez la définition des termes clés du chauffage aux pellets : granulés, silo, vis sans fin, ballon tampon, RGE, CEE, PCI et condensation.`}
  canonical="/glossaire"
  jsonLd={jsonLd}
>
  <section class="gradient-hero text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Glossaire", href: "/glossaire" },
      ]} />
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4 font-heading mt-6">
        📖 Glossaire & Lexique Technique
      </h1>
      <p class="text-amber-200 text-lg max-w-2xl">
        De A à Z, maîtrisez tous les concepts du chauffage biomasse comme un professionnel RGE certifié.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Letter filters -->
    <div class="flex flex-wrap gap-2 mb-8 justify-center bg-white p-4 rounded-2xl border border-amber-200 shadow-sm">
      <button class="px-4 py-2 rounded-lg bg-accent-500 text-white font-bold text-sm transition-all" id="btn-all">TOUT</button>
      {alphabet.map(letter => (
        <button
          class="w-10 h-10 rounded-lg bg-brand-50 hover:bg-brand-100 text-brand-800 font-bold transition-all border border-amber-100 flex items-center justify-center filter-letter"
          data-letter={letter}
        >
          {letter}
        </button>
      ))}
    </div>

    <!-- Search Input -->
    <div class="max-w-md mx-auto mb-10">
      <div class="relative">
        <input
          type="text"
          id="search-input"
          placeholder="Rechercher un terme technique (ex: silo, PCI...)"
          class="w-full bg-white border border-amber-200 focus:border-accent-500 rounded-xl px-5 py-3.5 shadow-sm text-brand-800 text-sm focus:outline-none transition-all"
        />
        <span class="absolute right-4 top-3.5 text-lg">🔍</span>
      </div>
    </div>

    <!-- Glossary List -->
    <div class="grid md:grid-cols-2 gap-6" id="glossary-container">
      {terms.map(t => (
        <div class="bg-white rounded-2xl border border-amber-200 p-6 shadow-sm card-hover glossary-item" data-letter={t.letter} data-word={t.word.toLowerCase()}>
          <div class="flex items-center gap-3 mb-3">
            <span class="w-8 h-8 rounded-lg bg-brand-600 text-white font-bold font-data flex items-center justify-center shadow-md">{t.letter}</span>
            <h2 class="text-lg font-bold text-brand-800 font-heading">{t.word}</h2>
          </div>
          <p class="text-sm text-brand-700 leading-relaxed">{t.definition}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12 bg-white rounded-2xl border border-amber-200 p-8 max-w-xl mx-auto shadow-sm" id="no-results" style="display: none;">
      <span class="text-4xl block mb-2">🤔</span>
      <h3 class="text-base font-bold text-brand-800">Aucun résultat trouvé</h3>
      <p class="text-xs text-brand-600 mt-1">Essayez un autre mot-clé ou filtrez par lettre alphabétique.</p>
    </div>
  </section>

  <!-- Interactive script to filter glossaire terms -->
  <script is:inline>
    (function() {
      const searchInput = document.getElementById('search-input');
      const letterBtns = document.querySelectorAll('.filter-letter');
      const allBtn = document.getElementById('btn-all');
      const items = document.querySelectorAll('.glossary-item');
      const noResults = document.getElementById('no-results');

      let currentLetter = 'ALL';
      let currentQuery = '';

      function filter() {
        let visibleCount = 0;

        items.forEach(item => {
          const letter = item.dataset.letter;
          const word = item.dataset.word;

          const matchesLetter = currentLetter === 'ALL' || letter === currentLetter;
          const matchesQuery = currentQuery === '' || word.includes(currentQuery);

          if (matchesLetter && matchesQuery) {
            item.style.display = 'block';
            visibleCount++;
          } else {
            item.style.display = 'none';
          }
        });

        if (visibleCount === 0) {
          noResults.style.display = 'block';
        } else {
          noResults.style.display = 'none';
        }
      }

      letterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          allBtn.classList.remove('bg-accent-500', 'text-white');
          allBtn.classList.add('bg-brand-50', 'text-brand-800');

          letterBtns.forEach(b => {
            b.classList.remove('bg-accent-500', 'text-white');
            b.classList.add('bg-brand-50', 'text-brand-800');
          });

          btn.classList.remove('bg-brand-50', 'text-brand-800');
          btn.classList.add('bg-accent-500', 'text-white');

          currentLetter = btn.dataset.letter;
          filter();
        });
      });

      allBtn.addEventListener('click', () => {
        letterBtns.forEach(b => {
          b.classList.remove('bg-accent-500', 'text-white');
          b.classList.add('bg-brand-50', 'text-brand-800');
        });

        allBtn.classList.remove('bg-brand-50', 'text-brand-800');
        allBtn.classList.add('bg-accent-500', 'text-white');

        currentLetter = 'ALL';
        filter();
      });

      searchInput.addEventListener('input', (e) => {
        currentQuery = e.target.value.toLowerCase().trim();
        filter();
      });
    })();
  </script>
</BaseLayout>
