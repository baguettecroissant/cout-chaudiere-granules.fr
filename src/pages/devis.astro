---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteWidget from '../components/QuoteWidget.astro';
import { siteConfig } from '../../site.config';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Demande de Devis Chaudière à Granulés de Bois",
    "description": "Demandez 3 devis gratuits d'installateurs certifiés RGE Qualibois pour votre chaudière à granulés.",
    "url": "https://" + siteConfig.domain + "/devis",
  }
];
---

<BaseLayout
  title={`Demande de Devis Chaudière Granulés Gratuit | ${siteConfig.name}`}
  description={`Remplissez le formulaire en 2 minutes et recevez jusqu'à 3 devis comparatifs gratuits d'installateurs certifiés RGE de votre département.`}
  canonical="/devis"
  jsonLd={jsonLd}
>
  <section class="gradient-hero text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Accueil", href: "/" },
        { label: "Demande de devis", href: "/devis" },
      ]} />
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4 font-heading mt-6">
        🔥 Demande de Devis Chaudière Granulés
      </h1>
      <p class="text-amber-200 text-lg max-w-xl">
        Comparez gratuitement les prix de 3 installateurs qualifiés RGE de votre région. Service 100% gratuit et sans engagement.
      </p>
    </div>
  </section>

  <section class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white rounded-2xl shadow-sm border border-amber-200 p-2">
      <QuoteWidget keyword="devis chaudiere granules" />
    </div>

    <!-- Info points -->
    <div class="mt-8 grid gap-4">
      <div class="flex gap-3 bg-brand-50 p-4 rounded-xl border border-amber-100">
        <span class="text-xl">✅</span>
        <div>
          <h4 class="font-bold text-brand-800 text-sm">Artisans certifiés RGE Qualibois</h4>
          <p class="text-xs text-brand-600 mt-0.5">La certification RGE de nos artisans partenaires est obligatoire pour vous rendre éligible aux aides nationales (MaPrimeRénov', CEE, etc.).</p>
        </div>
      </div>
      <div class="flex gap-3 bg-brand-50 p-4 rounded-xl border border-amber-100">
        <span class="text-xl">⏱️</span>
        <div>
          <h4 class="font-bold text-brand-800 text-sm">Réponse rapide sous 48h</h4>
          <p class="text-xs text-brand-600 mt-0.5">Dès la validation de votre formulaire, jusqu'à 3 professionnels locaux analysent votre projet et vous recontactent sous 24 à 48 heures maximum.</p>
        </div>
      </div>
    </div>

    <!-- Cross-links: Guides -->
    <div class="mt-10 bg-white rounded-2xl border border-amber-200 p-6 shadow-sm">
      <h3 class="text-lg font-bold text-brand-800 mb-4 font-heading">📚 Avant de demander un devis</h3>
      <div class="grid gap-3">
        <a href="/guides/prix-chaudiere-granules-2026" class="flex items-center gap-3 bg-brand-50 rounded-xl p-3 border border-amber-100 hover:border-accent-400 transition-all group">
          <span class="text-lg">💰</span>
          <span class="font-bold text-brand-800 group-hover:text-accent-500 text-sm">Prix Chaudière Granulés 2026 — Budget complet</span>
        </a>
        <a href="/guides/aides-chaudiere-granules-2026" class="flex items-center gap-3 bg-brand-50 rounded-xl p-3 border border-amber-100 hover:border-accent-400 transition-all group">
          <span class="text-lg">🏛️</span>
          <span class="font-bold text-brand-800 group-hover:text-accent-500 text-sm">Aides MaPrimeRénov' 2026 — Cumul et reste à charge</span>
        </a>
        <a href="/guides/remplacement-chaudiere-fioul-granules" class="flex items-center gap-3 bg-brand-50 rounded-xl p-3 border border-amber-100 hover:border-accent-400 transition-all group">
          <span class="text-lg">🔥</span>
          <span class="font-bold text-brand-800 group-hover:text-accent-500 text-sm">Remplacement Fioul → Granulés — Étapes et coûts</span>
        </a>
      </div>
      <div class="text-center mt-3">
        <a href="/guides" class="text-accent-500 hover:text-accent-600 font-semibold text-sm transition-colors">Tous les guides →</a>
      </div>
    </div>

    <!-- Cross-links: Marques + Simulateur -->
    <div class="mt-6 grid sm:grid-cols-2 gap-4">
      <a href="/marques" class="bg-white rounded-2xl border border-amber-200 p-5 hover:border-accent-400 hover:shadow-md transition-all group">
        <span class="text-2xl block mb-2">🏆</span>
        <h4 class="font-bold text-brand-800 group-hover:text-accent-500 text-sm">Comparatif Marques</h4>
        <p class="text-xs text-brand-600 mt-1">Ökofen, Fröling, Hargassner, De Dietrich...</p>
      </a>
      <a href="/simulateur-prix" class="bg-brand-700 text-white rounded-2xl border border-brand-800 p-5 hover:bg-brand-600 transition-all group shadow-md">
        <span class="text-2xl block mb-2">🧮</span>
        <h4 class="font-bold text-amber-300 group-hover:text-amber-200 text-sm">Simulateur de prix</h4>
        <p class="text-xs text-amber-200/80 mt-1">Estimez votre reste à charge en 2 minutes.</p>
      </a>
    </div>
  </section>
</BaseLayout>
