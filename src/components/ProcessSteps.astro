---
import { siteConfig } from '../../site.config';
---

<div class="bg-white rounded-2xl border border-amber-200 shadow-sm p-6 md:p-8" id="etapes-process">
  <h3 class="text-xl font-bold text-brand-800 mb-2 font-heading text-center">
    🏁 Votre installation en 4 étapes simples
  </h3>
  <p class="text-sm text-brand-600 mb-8 text-center max-w-xl mx-auto">
    Un parcours d'accompagnement complet et sécurisé de la demande de devis à la mise en service :
  </p>

  <div class="grid sm:grid-cols-4 gap-6 relative">
    {siteConfig.process.map((step, index) => (
      <div class="flex flex-col items-center text-center relative space-y-3 p-4 hover:bg-amber-50/30 rounded-xl transition-colors duration-200">
        <!-- Badge -->
        <span class="absolute top-2 right-2 font-data font-bold text-xs text-brand-600/30 bg-amber-100/50 w-6 h-6 rounded-full flex items-center justify-center">
          0{index + 1}
        </span>
        <span class="text-3xl filter drop-shadow">{step.icon}</span>
        <h4 class="font-bold text-brand-800 text-sm font-heading">{step.title}</h4>
        <p class="text-xs text-brand-600 leading-relaxed">{step.desc}</p>
        {'duration' in step && (
          <span class="inline-block bg-accent-500/10 text-accent-600 font-data font-semibold text-[10px] px-2 py-0.5 rounded-full mt-1">
            ⏱️ {step.duration}
          </span>
        )}
      </div>
    ))}
  </div>
</div>
