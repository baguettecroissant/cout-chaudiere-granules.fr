---
import { siteConfig } from '../../site.config';

interface Props {
  keyword?: string;
}

const { keyword = siteConfig.niche.name } = Astro.props;
---

<div class="bg-white rounded-2xl border border-amber-200 shadow-xl overflow-hidden" id="devis-form">
  <!-- Widget Header -->
  <div class="gradient-hero p-5 text-white text-center border-b border-amber-200">
    <h3 class="font-bold text-lg font-heading">
      🔥 Obtenez 3 Devis RGE Gratuits
    </h3>
    <p class="text-xs text-amber-200/80 mt-1">
      Service 100% gratuit, rapide et sans engagement
    </p>
  </div>

  <!-- ViteUnDevis Widget Container -->
  <div class="p-6 bg-amber-50/30">
    <div id="ve838806958d" class="vud-widget-container min-h-[420px]">
      <div class="vud-loader flex flex-col items-center justify-center py-12 text-brand-700/60 text-sm">
        <!-- Loader -->
        <svg class="animate-spin h-8 w-8 text-accent-500 mb-3" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span>Chargement sécurisé du formulaire...</span>
      </div>
    </div>

    <!-- Inline script for loading the ViteUnDevis widget -->
    <script is:inline>
      vud_partenaire_id = '2353';
      vud_categorie_id = '64';
      var vud_js = document.createElement('script'); vud_js.type = 'text/javascript';
      vud_js.src = '//www.viteundevis.com/e838806958/'+vud_partenaire_id+'/'+vud_categorie_id+'/';
      var s = document.getElementsByTagName('script')[0];
      s.parentNode.insertBefore(vud_js, s);

      // Hide and remove loader when the form container is appended
      const container = document.getElementById('ve838806958d');
      if (container) {
        const observer = new MutationObserver((mutations) => {
          if (document.getElementById('vud_mb_js_box')) {
            const loader = container.querySelector('.vud-loader');
            if (loader) {
              loader.remove();
            }
            observer.disconnect();
          }
        });
        observer.observe(container, { childList: true, subtree: true });
      }
    </script>
  </div>

  <!-- Trust block -->
  <div class="bg-amber-100/50 px-6 py-4 border-t border-amber-200/50 flex justify-around text-[10px] font-semibold text-brand-700">
    <span class="flex items-center gap-1">🔒 Sécurisé</span>
    <span class="flex items-center gap-1">⏱️ 2 minutes</span>
    <span class="flex items-center gap-1">🌿 Éco-responsable</span>
  </div>
</div>

<style>
  #ve838806958d:has(#vud_mb_js_box) .vud-loader {
    display: none !important;
  }
</style>
